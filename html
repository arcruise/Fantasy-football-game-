  }

  .back-btn {
    position: absolute; top: 2vh; left: 2vw;
    padding: 1vh 2vw;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    cursor: pointer;
    border-radius: 6px;
