  .menu-btn.secondary:hover { background: #ff006e; color: #fff; }
  .menu-btn:disabled { opacity: 0.3; cursor: not-allowed; transform: none; }

  .team-select-container { display: flex; width: 90%; height: 70%; gap: 2vw; }
  .team-panel {
    flex: 1;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 2vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow-y: auto;
  }
  .team-panel h2 { font-size: clamp(1rem, 2.5vw, 1.8rem); margin-bottom: 2vh; color: #00d4ff; }
  .team-panel.right h2 { color: #ff006e; }
  .team-item {
    width: 100%; padding: 1.5vh 1vw;
    margin: 0.5vh 0;
    background: rgba(255,255,255,0.05);
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 1vw;
    transition: all 0.2s;
  }
  .team-item:hover { background: rgba(255,255,255,0.1); border-color: #00d4ff; }
  .team-item.selected { background: rgba(0,212,255,0.2); border-color: #00d4ff; }
  .team-panel.right .team-item:hover { border-color: #ff006e; }
  .team-panel.right .team-item.selected { background: rgba(255,0,110,0.2); border-color: #ff006e; }
  .team-flag {
    width: 3vw; height: 3vw; min-width: 30px; min-height: 30px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
