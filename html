  }
  .start-match-btn:hover { transform: scale(1.1); }
  .start-match-btn:disabled { opacity: 0.3; cursor: not-allowed; transform: none; }

  .setup-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3vw;
    width: 80%;
    max-width: 800px;
  }
  .setup-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 3vh 2vw;
    text-align: center;
  }
  .setup-card h3 { font-size: clamp(1rem, 2.5vw, 1.5rem); margin-bottom: 2vh; color: #ffd700; }
  .setup-option {
    padding: 1.5vh 2vw;
    margin: 1vh 0;
    background: rgba(255,255,255,0.05);
    border: 2px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    transition: all 0.2s;
  }
  .setup-option:hover { border-color: #00d4ff; background: rgba(0,212,255,0.1); }
  .setup-option.selected { border-color: #00d4ff; background: rgba(0,212,255,0.2); color: #00d4ff; }

  .formation-preview {
    width: 100%; height: 20vh; min-height: 120px;
    background: rgba(0,100,0,0.2);
    border: 1px solid rgba(0,255,0,0.3);
    border-radius: 8px;
    margin-top: 2vh;
    position: relative;
  }
  .form-dot {
    position: absolute; width: 2vw; min-width: 12px; height: 2vw; min-height: 12px;
    border-radius: 50%; background: #00d4ff; transform: translate(-50%, -50%);
  }
  .form-dot.gk { background: #ffd700; }

  #hud {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: 5;
  }
  .hud-top {
    position: absolute; top: 1vh; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center; gap: 2vw;
    background: rgba(0,0,0,0.7);
    padding: 1vh 3vw;
    border-radius: 12px;
    backdrop-filter: blur(10px);
  }
  .hud-team { text-align: center; }
  .hud-team-name { font-size: clamp(0.7rem, 1.5vw, 1rem); font-weight: 700; }
  .hud-score { font-size: clamp(1.5rem, 4vw, 2.5rem); font-weight: 900; color: #ffd700; }
  .hud-time { font-size: clamp(1rem, 2.5vw, 1.5rem); font-weight: 700; color: #fff; min-width: 8vw; text-align: center; }
  .hud-possession {
    position: absolute; top: 1vh; right: 2vw;
    background: rgba(0,0,0,0.6);
    padding: 0.5vh 1vw;
    border-radius: 6px;
    font-size: clamp(0.6rem, 1.2vw, 0.8rem);
  }
  .hud-player-bar {
    position: absolute; bottom: 8vh; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center; gap: 1vw;
    background: rgba(0,0,0,0.6);
    padding: 0.8vh 2vw;
    border-radius: 8px;
    font-size: clamp(0.6rem, 1.2vw, 0.8rem);
  }
  .stamina-bar {
    width: 8vw; min-width: 60px; height: 6px; background: #333; border-radius: 3px; overflow: hidden;
  }
  .stamina-fill { height: 100%; background: linear-gradient(90deg, #ff4444, #ffdd00, #00ff44); transition: width 0.3s; }

  .power-bar-container {
    position: absolute; bottom: 15vh; left: 50%; transform: translateX(-50%);
    width: 15vw; min-width: 120px; height: 8px;
    background: rgba(0,0,0,0.6);
    border-radius: 4px; overflow: hidden;
    display: none;
  }
  .power-bar-fill {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, #00ff44, #ffdd00, #ff4444);
    transition: width 0.05s;
  }

  .touch-controls {
    position: absolute; bottom: 2vh;
    display: none; pointer-events: all;
    z-index: 15;
  }
  .touch-dpad {
    left: 3vw; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1vw;
    width: 22vw; min-width: 140px;
  }
  .touch-btn {
    width: 7vw; min-width: 45px; height: 7vw; min-height: 45px;
    background: rgba(255,255,255,0.15);
    border: 2px solid rgba(255,255,255,0.3);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    color: #fff;
    cursor: pointer;
    touch-action: none;
  }
  .touch-btn:active { background: rgba(0,212,255,0.4); border-color: #00d4ff; }
  .touch-actions {
    right: 3vw; display: flex; flex-direction: column; gap: 1.5vh; align-items: flex-end;
  }
  .touch-action-btn {
    width: 10vw; min-width: 60px; height: 10vw; min-height: 60px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: clamp(0.7rem, 1.8vw, 1rem);
    cursor: pointer; touch-action: none;
  }
  .btn-pass { background: rgba(0,212,255,0.3); border: 2px solid #00d4ff; color: #00d4ff; }
  .btn-shoot { background: rgba(255,0,110,0.3); border: 2px solid #ff006e; color: #ff006e; }
  .btn-sprint { background: rgba(255,215,0,0.3); border: 2px solid #ffd700; color: #ffd700; }
  .btn-switch { background: rgba(0,255,100,0.3); border: 2px solid #00ff64; color: #00ff64; font-size: clamp(0.6rem, 1.5vw, 0.8rem); }

  .pause-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.85);
    display: none; flex-direction: column; align-items: center; justify-content: center;
    z-index: 20; pointer-events: all;
  }
  .pause-overlay.active { display: flex; }
  .pause-title { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; margin-bottom: 4vh; color: #ffd700; }

  .goal-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.6);
    display: none; flex-direction: column; align-items: center; justify-content: center;
    z-index: 25; pointer-events: none;
  }
  .goal-overlay.active { display: flex; }
  .goal-text {
    font-size: clamp(3rem, 10vw, 8rem); font-weight: 900;
    color: #ffd700; text-shadow: 0 0 50px rgba(255,215,0,0.8);
    animation: goalPulse 1s ease-in-out infinite alternate;
  }
  @keyframes goalPulse { from { transform: scale(1); } to { transform: scale(1.1); } }
  .goal-scorer { font-size: clamp(1rem, 3vw, 2rem); color: #fff; margin-top: 2vh; }

  .gameover-stats {
    display: grid; grid-template-columns: 1fr auto 1fr;
    gap: 3vw; width: 80%; max-width: 600px;
    margin: 3vh 0;
  }
  .stat-box { text-align: center; }
  .stat-value { font-size: clamp(1.5rem, 4vw, 2.5rem); font-weight: 900; color: #00d4ff; }
  .stat-label { font-size: clamp(0.7rem, 1.5vw, 1rem); color: #888; }

  .online-status {
    position: absolute; top: 2vh; right: 2vw;
    padding: 0.8vh 1.5vw;
    border-radius: 6px;
    font-size: clamp(0.7rem, 1.5vw, 0.9rem);
    font-weight: 700;
    z-index: 20;
  }
  .online-status.connected { background: rgba(0,255,100,0.2); border: 1px solid #00ff64; color: #00ff64; }
  .online-status.connecting { background: rgba(255,200,0,0.2); border: 1px solid #ffd700; color: #ffd700; }
  .online-status.disconnected { background: rgba(255,0,0,0.2); border: 1px solid #ff4444; color: #ff4444; }

  .room-code {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    color: #ffd700;
    letter-spacing: 8px;
    margin: 2vh 0;
    padding: 2vh 4vw;
    background: rgba(255,255,255,0.05);
    border: 2px dashed #ffd700;
    border-radius: 12px;
  }

  .input-field {
    width: 60%; max-width: 300px;
    padding: 1.5vh 2vw;
    margin: 1vh 0;
    background: rgba(255,255,255,0.05);
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    color: #fff;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    text-align: center;
    outline: none;
    transition: border-color 0.3s;
  }
  .input-field:focus { border-color: #00d4ff; }

  .latency-display {
    position: absolute; top: 1vh; left: 2vw;
    font-size: clamp(0.6rem, 1.2vw, 0.8rem);
    color: #888;
    z-index: 20;
  }

  @media (max-aspect-ratio: 16/9) {
    #gameContainer { max-width: 100vw; max-height: 56.25vw; }
  }
  @media (pointer: coarse) {
    .touch-controls { display: flex; }
  }
</style>
</head>
<body>

<div id="gameContainer">
  <canvas id="gameCanvas"></canvas>

  <!-- MAIN MENU -->
  <div id="mainMenu" class="screen active">
    <div class="logo">eFOOTBALL</div>
    <div class="subtitle">Pro Evolution Soccer</div>
    <button class="menu-btn" onclick="goToTeamSelect('ai')">Exhibition Match (vs AI)</button>
    <button class="menu-btn" onclick="goToTeamSelect('pvp')">Local Multiplayer</button>
    <button class="menu-btn" onclick="goToOnlineMenu()" style="border-color: #00ff64; color: #00ff64; background: rgba(0,255,100,0.1);">Online Multiplayer</button>
    <button class="menu-btn secondary" onclick="showHowToPlay()">How to Play</button>
    <button class="menu-btn secondary" onclick="showSettings()">Settings</button>
  </div>

  <!-- ONLINE MENU -->
  <div id="onlineMenu" class="screen">
    <button class="back-btn" onclick="showScreen('mainMenu')">Back</button>
    <h2 style="font-size: clamp(1.5rem, 4vw, 2.5rem); margin-bottom: 2vh; color: #00ff64;">Online Multiplayer</h2>
    <p style="color: #888; margin-bottom: 3vh; font-size: clamp(0.8rem, 1.8vw, 1rem);">Connect to your server via WiFi / Hotspot</p>
    
    <input type="text" class="input-field" id="serverIP" placeholder="Server IP (e.g. 192.168.1.5)" value="localhost">
    <input type="text" class="input-field" id="serverPort" placeholder="Port (default 3000)" value="3000">
    
    <button class="menu-btn" onclick="hostOnlineGame()" style="margin-top: 2vh;">Host Game</button>
    <button class="menu-btn secondary" onclick="showJoinRoom()">Join Game</button>
  </div>

  <!-- HOST ROOM -->
  <div id="hostRoom" class="screen">
    <button class="back-btn" onclick="disconnect(); showScreen('onlineMenu')">Back</button>
    <div class="online-status connecting" id="hostStatus">Connecting...</div>
    <h2 style="font-size: clamp(1.5rem, 4vw, 2.5rem); margin-bottom: 2vh; color: #00d4ff;">Hosting Game</h2>
    <p style="color: #888; margin-bottom: 2vh;">Share this code with your friend:</p>
    <div class="room-code" id="roomCodeDisplay">----</div>
    <p style="color: #888; margin: 2vh 0; font-size: clamp(0.8rem, 1.8vw, 1rem);" id="hostMessage">Waiting for opponent...</p>
    <div id="hostTeamSelect" style="display: none; width: 80%;">
      <p style="color: #ffd700; margin-bottom: 2vh;">Select Your Team (Home):</p>
      <div style="max-height: 30vh; overflow-y: auto;" id="hostTeamList"></div>
      <button class="start-match-btn" id="hostReadyBtn" onclick="hostReady()" disabled>Ready</button>
    </div>
  </div>

  <!-- JOIN ROOM -->
  <div id="joinRoom" class="screen">
    <button class="back-btn" onclick="disconnect(); showScreen('onlineMenu')">Back</button>
    <div class="online-status disconnected" id="joinStatus">Disconnected</div>
    <h2 style="font-size: clamp(1.5rem, 4vw, 2.5rem); margin-bottom: 2vh; color: #ff006e;">Join Game</h2>
    <input type="text" class="input-field" id="joinRoomCode" placeholder="Enter Room Code" maxlength="4">
    <button class="menu-btn" onclick="joinOnlineGame()" style="margin-top: 2vh;">Connect</button>
    <div id="joinTeamSelect" style="display: none; width: 80%; margin-top: 3vh;">
      <p style="color: #ffd700; margin-bottom: 2vh;">Select Your Team (Away):</p>
      <div style="max-height: 30vh; overflow-y: auto;" id="joinTeamList"></div>
      <button class="start-match-btn" id="joinReadyBtn" onclick="joinReady()" disabled>Ready</button>
    </div>
  </div>

  <!-- TEAM SELECT -->
  <div id="teamSelect" class="screen">
    <button class="back-btn" onclick="showScreen('mainMenu')">Back</button>
    <h2 style="font-size: clamp(1.5rem, 4vw, 2.5rem); margin-bottom: 2vh; color: #ffd700;">Select Teams</h2>
    <div class="team-select-container">
      <div class="team-panel" id="teamPanel1">
        <h2>Home Team</h2>
        <div id="teamList1"></div>
      </div>
      <div class="vs-divider">VS</div>
      <div class="team-panel right" id="teamPanel2">
        <h2>Away Team</h2>
        <div id="teamList2"></div>
      </div>
    </div>
    <button class="start-match-btn" id="toSetupBtn" onclick="goToSetup()" disabled>Continue</button>
  </div>

  <!-- MATCH SETUP -->
  <div id="matchSetup" class="screen">
    <button class="back-btn" onclick="showScreen('teamSelect')">Back</button>
    <h2 style="font-size: clamp(1.5rem, 4vw, 2.5rem); margin-bottom: 3vh; color: #ffd700;">Match Setup</h2>
    <div class="setup-grid">
      <div class="setup-card">
        <h3>Match Duration</h3>
        <div class="setup-option selected" data-duration="3" onclick="selectDuration(this)">3 Minutes</div>
        <div class="setup-option" data-duration="5" onclick="selectDuration(this)">5 Minutes</div>
        <div class="setup-option" data-duration="10" onclick="selectDuration(this)">10 Minutes</div>
      </div>
      <div class="setup-card">
        <h3>Difficulty</h3>
        <div class="setup-option selected" data-diff="medium" onclick="selectDiff(this)">Medium</div>
        <div class="setup-option" data-diff="hard" onclick="selectDiff(this)">Hard</div>
        <div class="setup-option" data-diff="easy" onclick="selectDiff(this)">Easy</div>
      </div>
      <div class="setup-card">
        <h3>Home Formation</h3>
        <div class="setup-option selected" data-form="433" onclick="selectFormation(0, this)">4-3-3</div>
        <div class="setup-option" data-form="442" onclick="selectFormation(0, this)">4-4-2</div>
        <div class="setup-option" data-form="4231" onclick="selectFormation(0, this)">4-2-3-1</div>
        <div class="formation-preview" id="formPreview1"></div>
      </div>
      <div class="setup-card">
        <h3>Away Formation</h3>
        <div class="setup-option selected" data-form="433" onclick="selectFormation(1, this)">4-3-3</div>
        <div class="setup-option" data-form="442" onclick="selectFormation(1, this)">4-4-2</div>
        <div class="setup-option" data-form="4231" onclick="selectFormation(1, this)">4-2-3-1</div>
        <div class="formation-preview" id="formPreview2"></div>
      </div>
    </div>
    <button class="start-match-btn" onclick="startMatch()" style="margin-top: 3vh;">Kick Off!</button>
  </div>

  <!-- HOW TO PLAY -->
  <div id="howToPlay" class="screen">
    <button class="back-btn" onclick="showScreen('mainMenu')">Back</button>
    <h2 style="font-size: clamp(1.5rem, 4vw, 2.5rem); margin-bottom: 3vh; color: #00d4ff;">Controls</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3vw; width: 85%; max-width: 800px;">
      <div style="background: rgba(255,255,255,0.03); border-radius: 12px; padding: 3vh 2vw;">
        <h3 style="color: #00d4ff; margin-bottom: 2vh;">Player 1 (Home)</h3>
        <p style="margin: 1vh 0; font-size: clamp(0.8rem, 1.8vw, 1rem);"><b>WASD</b> - Move</p>
        <p style="margin: 1vh 0; font-size: clamp(0.8rem, 1.8vw, 1rem);"><b>Space</b> - Pass / Shoot (hold for power)</p>
        <p style="margin: 1vh 0; font-size: clamp(0.8rem, 1.8vw, 1rem);"><b>Q</b> - Through Ball</p>
        <p style="margin: 1vh 0; font-size: clamp(0.8rem, 1.8vw, 1rem);"><b>E</b> - Sprint</p>
        <p style="margin: 1vh 0; font-size: clamp(0.8rem, 1.8vw, 1rem);"><b>R</b> - Switch Player</p>
      </div>
      <div style="background: rgba(255,255,255,0.03); border-radius: 12px; padding: 3vh 2vw;">
        <h3 style="color: #ff006e; margin-bottom: 2vh;">Player 2 (Away)</h3>
        <p style="margin: 1vh 0; font-size: clamp(0.8rem, 1.8vw, 1rem);"><b>Arrow Keys</b> - Move</p>
        <p style="margin: 1vh 0; font-size: clamp(0.8rem, 1.8vw, 1rem);"><b>Enter</b> - Pass / Shoot (hold for power)</p>
