function initMatch() {
  matchTime = 0;
  score = [0, 0];
  possession = [0, 0];
  shots = [0, 0];
  saves = [0, 0];
  lastPossession = -1;
  particles = [];
  kickoffTeam = Math.floor(Math.random() * 2);
  
  players = [[], []];
  [0, 1].forEach(t => {
    const team = TEAMS[selectedTeam[t]];
    const form = FORMATIONS[selectedFormation[t]];
    const isAway = t === 1;
    form.positions.forEach((p, i) => {
      const px = isAway ? 1 - p.x : p.x;
      const py = isAway ? 1 - p.y : p.y;
      const isGk = i === 0;
      const baseSpeed = 0.003 + (team.mid / 100) * 0.002;
      players[t].push({
        x: px, y: py,
        vx: 0, vy: 0,
        team: t, index: i,
        isGk: isGk,
        speed: isGk ? baseSpeed * 0.9 : baseSpeed * (0.9 + Math.random() * 0.2),
        stamina: 100,
        name: isGk ? 'GK' : (t === 0 ? 'H' : 'A') + (i),
        homeX: px, homeY: py,
        state: 'idle',
        hasBall: false,
        tackleCooldown: 0,
        shotPower: 0
      });
    });
  });
  
  activePlayer = [5, 5];
  resetBall(kickoffTeam);
  updateHUD();
}

function resetBall(team) {
  ball.x = 0.5;
  ball.y = team === 0 ? 0.55 : 0.45;
  ball.vx = 0; ball.vy = 0;
  ball.z = 0; ball.vz = 0;
  ball.owner = null;
  const striker = players[team][players[team].length - 1];
  ball.x = striker.x; ball.y = striker.y;
  ball.owner = striker;
  striker.hasBall = true;
  activePlayer[team] = players[team].length - 1;
}

function startMatchTimer() {
  if (matchTimer) clearInterval(matchTimer);
  matchTimer = setInterval(() => {
    if (gameState === 'playing') {
      matchTime += 1/60;
      if (matchTime >= matchDuration * 60) {
        endMatch();
      }
      updateHUD();
    }
  }, 1000 / 60);
}

// ==================== GAME LOOP ====================
function gameLoop() {
  if (gameState === 'playing' || gameState === 'goal') {
    update();
    render();
  }
  requestAnimationFrame(gameLoop);
}

function update() {
  const dt = 0.016 * gameSpeed;
  
  if (gameState === 'goal') {
    goalTimer -= dt;
    if (goalTimer <= 0) {
      gameState = 'playing';
      document.getElementById('goalOverlay').classList.remove('active');
      resetBall(kickoffTeam);
    }
    updateParticles(dt);
    return;
  }
  
  // Send inputs to server if online
  if (netState === 'playing') {
    syncTimer += dt;
    if (syncTimer > 0.05) { // 20Hz input send
      syncTimer = 0;
      send({
        type: 'input',
        roomCode,
        data: {
          keys: { ...keys },
          activePlayer: activePlayer[myTeam]
        }
      });
    }
    // Ping every second
    if (Math.floor(matchTime * 10) % 10 === 0) {
      lastPingTime = Date.now();
      send({ type: 'ping' });
    }
  }
  
  // Handle inputs
  handleInput(0);
  if (gameMode === 'pvp') handleInput(1);
  else if (gameMode === 'ai') handleAI(1);
  else if (netState === 'playing') {
    // Apply network inputs for opponent
    applyNetworkInputs(1 - myTeam);
  }
  
  // Update players
  players.forEach((team, ti) => {
    team.forEach((p, pi) => {
      if (p.tackleCooldown > 0) p.tackleCooldown -= dt;
      if (!keys['KeyE'] && !(gameMode === 'pvp' && keys['ShiftLeft'])) {
        p.stamina = Math.min(100, p.stamina + 5 * dt);
      }
      p.x += p.vx * dt;
      p.y += p.vy * dt;
      p.vx *= 0.9;
      p.vy *= 0.9;
      p.x = Math.max(0.02, Math.min(0.98, p.x));
      p.y = Math.max(0.02, Math.min(0.98, p.y));
      if (ball.owner === p) {
        ball.x = p.x + p.vx * 0.5;
        ball.y = p.y + p.vy * 0.5;
      }
    });
  });
  
  // Ball physics
  if (!ball.owner) {
    ball.x += ball.vx * dt;
    ball.y += ball.vy * dt;
    ball.z += ball.vz * dt;
    ball.vz -= 15 * dt;
    if (ball.z <= 0) { ball.z = 0; ball.vz *= -0.5; }
    ball.vx *= 0.98;
    ball.vy *= 0.98;
    
    // Ball sync interpolation for online
    if (ballSync && netState === 'playing') {
      ball.x += (ballSync.x - ball.x) * 0.3;
      ball.y += (ballSync.y - ball.y) * 0.3;
      ball.vx += (ballSync.vx - ball.vx) * 0.3;
      ball.vy += (ballSync.vy - ball.vy) * 0.3;
      ballSync = null;
    }
    
    if (ball.x > 0.42 && ball.x < 0.58) {
      if (ball.y <= 0.03) { scoreGoal(0, true); return; }
      if (ball.y >= 0.97) { scoreGoal(1, true); return; }
    }
    
    if (ball.x < 0 || ball.x > 1) {
      ball.vx *= -0.8;
      ball.x = Math.max(0.01, Math.min(0.99, ball.x));
    }
    if (ball.y < 0 || ball.y > 1) {
      if (!(ball.x > 0.42 && ball.x < 0.58)) {
        ball.vy *= -0.8;
        ball.y = Math.max(0.01, Math.min(0.99, ball.y));
      }
    }
    
    let closest = null, closestDist = 0.06;
    players.forEach(team => {
      team.forEach(p => {
        const dx = p.x - ball.x, dy = p.y - ball.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < closestDist) {
          closestDist = dist;
          closest = p;
        }
      });
    });
    if (closest) {
      ball.owner = closest;
      closest.hasBall = true;
      activePlayer[closest.team] = closest.index;
      if (lastPossession !== closest.team) {
        lastPossession = closest.team;
      }
    }
  }
  
  // Camera
  let targetX = ball.x * W - W/2;
  let targetY = ball.y * H - H/2;
  camera.x += (targetX - camera.x) * 0.05;
  camera.y += (targetY - camera.y) * 0.05;
  if (camera.shake > 0) camera.shake -= dt * 10;
  
  updateParticles(dt);
}

function applyNetworkInputs(team) {
  if (!networkInputs.keys) return;
  const nk = networkInputs.keys;
  const p = players[team][networkInputs.activePlayer || 0];
  if (!p || p.tackleCooldown > 0) return;
  
  let mx = 0, my = 0;
  const speed = p.speed * (p.stamina > 20 ? 1 : 0.7);
  
  if (nk['ArrowUp']) my -= 1;
  if (nk['ArrowDown']) my += 1;
  if (nk['ArrowLeft']) mx -= 1;
  if (nk['ArrowRight']) mx += 1;
  
  const isSprinting = nk['ShiftLeft'] && p.stamina > 10;
  const moveSpeed = speed * (isSprinting ? 1.6 : 1.0);
  
  if (mx !== 0 || my !== 0) {
    const len = Math.sqrt(mx*mx + my*my);
    p.vx = (mx/len) * moveSpeed * 60;
    p.vy = (my/len) * moveSpeed * 60;
    if (isSprinting) p.stamina -= 15 * 0.016;
    p.state = isSprinting ? 'sprint' : 'run';
  } else {
    p.state = 'idle';
  }
  
  if (nk['Enter']) {
    if (!powerCharging && ball.owner === p) {
      powerCharging = true;
      power = 0;
    }
    if (powerCharging) {
      power = Math.min(1, power + 0.02);
      document.getElementById('powerBar').style.display = 'block';
      document.getElementById('powerFill').style.width = (power * 100) + '%';
    }
  } else if (powerCharging) {
    executeAction(p, power);
    powerCharging = false;
    power = 0;
    document.getElementById('powerBar').style.display = 'none';
    document.getElementById('powerFill').style.width = '0%';
  }
  
  if (nk['Slash']) {
    switchPlayer(team);
    nk['Slash'] = false;
  }
}

function handleInput(team) {
  // In online mode, only handle local team
  if (netState === 'playing' && team !== myTeam) return;
  
  const isP1 = team === 0;
  const p = players[team][activePlayer[team]];
  if (!p || p.tackleCooldown > 0) return;
  
  let mx = 0, my = 0;
  const speed = p.speed * (p.stamina > 20 ? 1 : 0.7);
  
  if (isP1) {
    if (keys['KeyW']) my -= 1;
    if (keys['KeyS']) my += 1;
    if (keys['KeyA']) mx -= 1;
    if (keys['KeyD']) mx += 1;
  } else {
    if (keys['ArrowUp']) my -= 1;
    if (keys['ArrowDown']) my += 1;
    if (keys['ArrowLeft']) mx -= 1;
    if (keys['ArrowRight']) mx += 1;
  }
  
  const sprintKey = isP1 ? 'KeyE' : 'ShiftLeft';
  const isSprinting = keys[sprintKey] && p.stamina > 10;
  const moveSpeed = speed * (isSprinting ? 1.6 : 1.0);
  
  if (mx !== 0 || my !== 0) {
    const len = Math.sqrt(mx*mx + my*my);
    p.vx = (mx/len) * moveSpeed * 60;
    p.vy = (my/len) * moveSpeed * 60;
    if (isSprinting) p.stamina -= 15 * 0.016;
    p.state = isSprinting ? 'sprint' : 'run';
  } else {
    p.state = 'idle';
  }
  
  const actionKey = isP1 ? 'Space' : 'Enter';
  if (keys[actionKey]) {
    if (!powerCharging && ball.owner === p) {
      powerCharging = true;
      power = 0;
    }
    if (powerCharging) {
      power = Math.min(1, power + 0.02);
      document.getElementById('powerBar').style.display = 'block';
      document.getElementById('powerFill').style.width = (power * 100) + '%';
    }
  } else if (powerCharging) {
    executeAction(p, power);
    powerCharging = false;
    power = 0;
    document.getElementById('powerBar').style.display = 'none';
    document.getElementById('powerFill').style.width = '0%';
  }
  
  const throughKey = isP1 ? 'KeyQ' : null;
  if (throughKey && keys[throughKey] && ball.owner === p) {
    passBall(p, true);
    keys[throughKey] = false;
  }
  
  const switchKey = isP1 ? 'KeyR' : 'Slash';
  if (keys[switchKey]) {
    switchPlayer(team);
    keys[switchKey] = false;
  }
}

function handleAI(team) {
  const teamPlayers = players[team];
  const oppTeam = team === 0 ? 1 : 0;
  const oppPlayers = players[oppTeam];
  const ai = teamPlayers[activePlayer[team]];
  if (!ai || ai.tackleCooldown > 0) return;
  
  const diffMult = difficulty === 'easy' ? 0.6 : difficulty === 'hard' ? 1.3 : 1.0;
  
  if (ball.owner && ball.owner.team === team) {
    ai.state = 'attack';
    const goalX = 0.5, goalY = team === 0 ? 0 : 1;
    const dx = goalX - ai.x, dy = goalY - ai.y;
    const distToGoal = Math.sqrt(dx*dx + dy*dy);
    
    let bestPass = null, bestScore = -999;
    teamPlayers.forEach(tp => {
      if (tp === ai) return;
      const tdx = tp.x - ai.x, tdy = tp.y - ai.y;
      const tdist = Math.sqrt(tdx*tdx + tdy*tdy);
      if (tdist > 0.4 || tdist < 0.08) return;
      let open = true;
      oppPlayers.forEach(op => {
        const odx = op.x - tp.x, ody = op.y - tp.y;
        if (Math.sqrt(odx*odx + ody*ody) < 0.12) open = false;
      });
      if (open) {
        const score = (team === 0 ? 1 - tp.y : tp.y) - tdist * 0.5;
        if (score > bestScore) { bestScore = score; bestPass = tp; }
      }
    });
    
    if (distToGoal < 0.2 && Math.random() < 0.03 * diffMult) {
      shootBall(ai, 0.7 + Math.random() * 0.3);
    } else if (bestPass && Math.random() < 0.02 * diffMult) {
      passBall(ai, false, bestPass);
    } else {
      const speed = ai.speed * 60 * diffMult;
      ai.vx = (dx / distToGoal) * speed * 0.8;
      ai.vy = (dy / distToGoal) * speed * 0.8;
    }
  } else {
    ai.state = 'defend';
    const target = ball.owner || ball;
    const dx = target.x - ai.x, dy = target.y - ai.y;
    const dist = Math.sqrt(dx*dx + dy*dy);
    
    if (dist < 0.15 && Math.random() < 0.05 * diffMult) {
      tackle(ai);
    } else {
      const speed = ai.speed * 60 * diffMult * (dist > 0.3 ? 1.2 : 0.9);
      ai.vx = (dx / dist) * speed;
      ai.vy = (dy / dist) * speed;
    }
    
    let closest = activePlayer[team];
    let closestDist = dist;
    teamPlayers.forEach((tp, i) => {
      if (tp.isGk) return;
      const tdx = tp.x - ball.x, tdy = tp.y - ball.y;
      const tdist = Math.sqrt(tdx*tdx + tdy*tdy);
      if (tdist < closestDist) { closestDist = tdist; closest = i; }
    });
    if (closest !== activePlayer[team] && Math.random() < 0.1) {
      activePlayer[team] = closest;
    }
  }
  
  teamPlayers.forEach((tp, i) => {
    if (i === activePlayer[team]) return;
    const hdx = tp.homeX - tp.x, hdy = tp.homeY - tp.y;
    const hdist = Math.sqrt(hdx*hdx + hdy*hdy);
    if (hdist > 0.05) {
      tp.vx = (hdx / hdist) * ai.speed * 30;
      tp.vy = (hdy / hdist) * ai.speed * 30;
    }
    if (ball.owner && ball.owner.team === team) {
      tp.vy += (team === 0 ? -1 : 1) * ai.speed * 10;
    }
  });
}

function executeAction(p, power) {
  const goalY = p.team === 0 ? 0 : 1;
  const dy = goalY - p.y;
  if (Math.abs(dy) < 0.35 && Math.abs(p.x - 0.5) < 0.2 && power > 0.4) {
    shootBall(p, power);
  } else {
    passBall(p, false);
  }
}

function shootBall(p, power) {
  if (ball.owner !== p) return;
  ball.owner = null;
  p.hasBall = false;
  shots[p.team]++;
  
  const goalX = 0.5 + (Math.random() - 0.5) * 0.1;
  const goalY = p.team === 0 ? 0 : 1;
  const dx = goalX - p.x, dy = goalY - p.y;
  const dist = Math.sqrt(dx*dx + dy*dy);
  
  const speed = 0.4 + power * 0.4;
  ball.vx = (dx / dist) * speed;
  ball.vy = (dy / dist) * speed;
  ball.vz = 0.2 + power * 0.3;
  
  spawnParticles(p.x, p.y, '#fff', 10);
  if (cameraShake) camera.shake = 5;
}

function passBall(p, through, target = null) {
  if (ball.owner !== p) return;
  ball.owner = null;
  p.hasBall = false;
  
  if (!target) {
    let best = null, bestDist = 999;
    players[p.team].forEach(tp => {
      if (tp === p) return;
      const dx = tp.x - p.x, dy = tp.y - p.y;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 0.5 && dist > 0.1 && dist < bestDist) {
        bestDist = dist;
        best = tp;
      }
    });
    target = best;
  }
  
  if (target) {
    const dx = target.x - p.x, dy = target.y - p.y;
    const dist = Math.sqrt(dx*dx + dy*dy);
    const speed = through ? 0.5 : 0.25;
    ball.vx = (dx / dist) * speed;
    ball.vy = (dy / dist) * speed;
    if (through) { ball.vx *= 1.5; ball.vy *= 1.5; ball.vz = 0.1; }
    activePlayer[p.team] = target.index;
  }
}

function tackle(p) {
  if (p.tackleCooldown > 0) return;
  p.tackleCooldown = 1.0;
  p.state = 'tackle';
  const slideSpeed = 0.15;
  if (Math.abs(p.vx) > 0.001 || Math.abs(p.vy) > 0.001) {
    const len = Math.sqrt(p.vx*p.vx + p.vy*p.vy);
    p.vx = (p.vx/len) * slideSpeed * 60;
    p.vy = (p.vy/len) * slideSpeed * 60;
  }
  if (ball.owner && ball.owner.team !== p.team) {
    const dx = ball.x - p.x, dy = ball.y - p.y;
    if (Math.sqrt(dx*dx + dy*dy) < 0.06) {
      ball.owner.hasBall = false;
      ball.owner = p;
      p.hasBall = true;
      spawnParticles(p.x, p.y, '#ff4444', 5);
    }
  }
}

function switchPlayer(team) {
  const teamPlayers = players[team];
  let best = activePlayer[team];
  let bestDist = 999;
  teamPlayers.forEach((tp, i) => {
    if (tp.isGk) return;
    const dx = tp.x - ball.x, dy = tp.y - ball.y;
    const dist = Math.sqrt(dx*dx + dy*dy);
    if (dist < bestDist && i !== activePlayer[team]) {
      bestDist = dist;
      best = i;
    }
  });
  activePlayer[team] = best;
}

function scoreGoal(scoringTeam, notifyServer) {
  gameState = 'goal';
  score[scoringTeam]++;
  goalTimer = 3;
  kickoffTeam = 1 - scoringTeam;
  
  const scorer = ball.owner ? ball.owner.name : 'Unknown';
  document.getElementById('goalScorer').textContent = TEAMS[selectedTeam[scoringTeam]].name + ' - ' + scorer;
  document.getElementById('goalOverlay').classList.add('active');
  
  spawnParticles(ball.x, ball.y, '#ffd700', 30);
  if (cameraShake) camera.shake = 10;
  
  if (notifyServer && netState === 'playing') {
    send({ type: 'goal', roomCode, scoringTeam });
  }
  
  updateHUD();
}

function endMatch() {
  gameState = 'gameover';
  clearInterval(matchTimer);
  document.getElementById('hud').style.display = 'none';
  document.getElementById('touchDpad').style.display = 'none';
  document.getElementById('touchActions').style.display = 'none';
  
  document.getElementById('endTeam1').textContent = TEAMS[selectedTeam[0]].name;
  document.getElementById('endTeam2').textContent = TEAMS[selectedTeam[1]].name;
  document.getElementById('endScore').textContent = score[0] + ' - ' + score[1];
  
  const total = possession[0] + possession[1];
  const p1 = total > 0 ? Math.round(possession[0] / total * 100) : 50;
  document.getElementById('statPoss1').textContent = p1 + '%';
  document.getElementById('statPoss2').textContent = (100 - p1) + '%';
  document.getElementById('statShots1').textContent = shots[0];
  document.getElementById('statShots2').textContent = shots[1];
  document.getElementById('statSaves1').textContent = saves[0];
  document.getElementById('statSaves2').textContent = saves[1];
  
  showScreen('gameOver');
}

function togglePause() {
  const overlay = document.getElementById('pauseOverlay');
  if (gameState === 'playing') {
    gameState = 'paused';
    overlay.classList.add('active');
  } else if (gameState === 'paused') {
    resumeGame();
  }
}

function resumeGame() {
  gameState = 'playing';
  document.getElementById('pauseOverlay').classList.remove('active');
}

function restartMatch() {
  document.getElementById('pauseOverlay').classList.remove('active');
  document.getElementById('goalOverlay').classList.remove('active');
  initMatch();
  gameState = 'playing';
  updateHUD();
}

function quitToMenu() {
  clearInterval(matchTimer);
  gameState = 'menu';
  netState = 'offline';
  disconnect();
  document.getElementById('hud').style.display = 'none';
  document.getElementById('pauseOverlay').classList.remove('active');
  document.getElementById('goalOverlay').classList.remove('active');
  document.getElementById('touchDpad').style.display = 'none';
  document.getElementById('touchActions').style.display = 'none';
  showScreen('mainMenu');
}

// ==================== RENDERING ====================
function render() {
  ctx.fillStyle = '#0a5f0a';
  ctx.fillRect(0, 0, W, H);
  
  ctx.save();
  let cx = -camera.x, cy = -camera.y;
  if (camera.shake > 0) {
    cx += (Math.random() - 0.5) * camera.shake * 10;
    cy += (Math.random() - 0.5) * camera.shake * 10;
  }
  ctx.translate(cx, cy);
  
  const pw = W, ph = H;
  
  ctx.fillStyle = '#1a7a1a';
  ctx.fillRect(0, 0, pw, ph);
  
  ctx.fillStyle = '#157a15';
  for (let i = 0; i < 10; i += 2) {
    ctx.fillRect(0, i * ph / 10, pw, ph / 10);
  }
  
  ctx.strokeStyle = 'rgba(255,255,255,0.7)';
  ctx.lineWidth = 2 * SCALE;
  ctx.strokeRect(pw * 0.05, ph * 0.05, pw * 0.9, ph * 0.9);
  
  ctx.beginPath();
  ctx.moveTo(pw * 0.05, ph * 0.5);
  ctx.lineTo(pw * 0.95, ph * 0.5);
  ctx.stroke();
  
  ctx.beginPath();
  ctx.arc(pw * 0.5, ph * 0.5, pw * 0.08, 0, Math.PI * 2);
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(pw * 0.5, ph * 0.5, 3 * SCALE, 0, Math.PI * 2);
  ctx.fillStyle = '#fff';
  ctx.fill();
  
  ctx.strokeRect(pw * 0.25, ph * 0.05, pw * 0.5, ph * 0.15);
  ctx.strokeRect(pw * 0.35, ph * 0.05, pw * 0.3, ph * 0.05);
  ctx.strokeRect(pw * 0.25, ph * 0.8, pw * 0.5, ph * 0.15);
  ctx.strokeRect(pw * 0.35, ph * 0.9, pw * 0.3, ph * 0.05);
  
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.fillRect(pw * 0.42, ph * 0.02, pw * 0.16, ph * 0.03);
  ctx.fillRect(pw * 0.42, ph * 0.95, pw * 0.16, ph * 0.03);
  
  ctx.beginPath();
  ctx.arc(pw * 0.05, ph * 0.05, pw * 0.03, 0, Math.PI / 2);
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(pw * 0.95, ph * 0.05, pw * 0.03, Math.PI / 2, Math.PI);
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(pw * 0.05, ph * 0.95, pw * 0.03, -Math.PI / 2, 0);
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(pw * 0.95, ph * 0.95, pw * 0.03, Math.PI, -Math.PI / 2);
  ctx.stroke();
  
  players.forEach((team, ti) => {
    const teamColor = TEAMS[selectedTeam[ti]].color;
    const darkColor = TEAMS[selectedTeam[ti]].dark;
    
    team.forEach((p, pi) => {
      const px = p.x * pw, py = p.y * ph;
      const isActive = activePlayer[ti] === pi;
      const radius = p.isGk ? 10 * SCALE : 8 * SCALE;
      
      ctx.fillStyle = 'rgba(0,0,0,0.3)';
      ctx.beginPath();
      ctx.ellipse(px, py + radius * 0.5, radius, radius * 0.4, 0, 0, Math.PI * 2);
      ctx.fill();
      
      ctx.fillStyle = teamColor;
      ctx.beginPath();
      ctx.arc(px, py - ball.z * ph * 0.5, radius, 0, Math.PI * 2);
      ctx.fill();
      
      ctx.strokeStyle = darkColor;
      ctx.lineWidth = 2 * SCALE;
      ctx.stroke();
      
      ctx.fillStyle = '#fff';
      ctx.font = `bold ${radius}px Arial`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(p.isGk ? '1' : (pi + 1).toString(), px, py - ball.z * ph * 0.5);
      
      if (isActive && (gameMode === 'pvp' || ti === 0 || (netState === 'playing' && ti === myTeam))) {
        ctx.strokeStyle = '#ffd700';
        ctx.lineWidth = 3 * SCALE;
        ctx.beginPath();
        ctx.arc(px, py - ball.z * ph * 0.5, radius + 3 * SCALE, 0, Math.PI * 2);
        ctx.stroke();
        
        ctx.fillStyle = '#ffd700';
        ctx.beginPath();
        ctx.moveTo(px, py - radius * 2 - ball.z * ph * 0.5);
        ctx.lineTo(px - 5 * SCALE, py - radius * 2.8 - ball.z * ph * 0.5);
        ctx.lineTo(px + 5 * SCALE, py - radius * 2.8 - ball.z * ph * 0.5);
        ctx.fill();
      }
      
      if (isActive) {
        const barW = radius * 2;
        const barH = 3 * SCALE;
        ctx.fillStyle = '#333';
        ctx.fillRect(px - barW/2, py + radius + 2 * SCALE, barW, barH);
        ctx.fillStyle = p.stamina > 50 ? '#00ff44' : p.stamina > 25 ? '#ffdd00' : '#ff4444';
        ctx.fillRect(px - barW/2, py + radius + 2 * SCALE, barW * (p.stamina / 100), barH);
      }
    });
  });
  
  const bx = ball.x * pw, by = ball.y * ph;
  const ballSize = 5 * SCALE;
  const ballY = by - ball.z * ph * 0.3;
  
  ctx.fillStyle = 'rgba(0,0,0,0.3)';
  ctx.beginPath();
  ctx.ellipse(bx, by + ballSize * 0.3, ballSize, ballSize * 0.4, 0, 0, Math.PI * 2);
  ctx.fill();
  
  ctx.fillStyle = '#fff';
  ctx.beginPath();
  ctx.arc(bx, ballY, ballSize, 0, Math.PI * 2);
  ctx.fill();
  ctx.fillStyle = '#333';
  ctx.beginPath();
  ctx.arc(bx - ballSize * 0.3, ballY - ballSize * 0.3, ballSize * 0.4, 0, Math.PI * 2);
  ctx.fill();
  ctx.fillStyle = '#fff';
  ctx.beginPath();
  ctx.arc(bx - ballSize * 0.3, ballY - ballSize * 0.3, ballSize * 0.2, 0, Math.PI * 2);
  ctx.fill();
  
  particles.forEach(pt => {
    ctx.globalAlpha = pt.life;
    ctx.fillStyle = pt.color;
    ctx.beginPath();
    ctx.arc(pt.x * pw, pt.y * ph, pt.size * SCALE, 0, Math.PI * 2);
    ctx.fill();
  });
  ctx.globalAlpha = 1;
  
  ctx.restore();
  
  drawMinimap();
}

function drawMinimap() {
  const mw = W * 0.18, mh = H * 0.12;
  const mx = W - mw - 10, my = H - mh - 10;
  
  ctx.fillStyle = 'rgba(0,0,0,0.6)';
  ctx.fillRect(mx, my, mw, mh);
  ctx.strokeStyle = 'rgba(255,255,255,0.3)';
  ctx.lineWidth = 1;
  ctx.strokeRect(mx, my, mw, mh);
  
  ctx.beginPath();
  ctx.moveTo(mx, my + mh / 2);
  ctx.lineTo(mx + mw, my + mh / 2);
  ctx.stroke();
  
  players.forEach((team, ti) => {
    const color = TEAMS[selectedTeam[ti]].color;
    team.forEach(p => {
      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.arc(mx + p.x * mw, my + p.y * mh, 2 * SCALE, 0, Math.PI * 2);
      ctx.fill();
    });
  });
  
  ctx.fillStyle = '#fff';
  ctx.beginPath();
  ctx.arc(mx + ball.x * mw, my + ball.y * mh, 2.5 * SCALE, 0, Math.PI * 2);
  ctx.fill();
}

function spawnParticles(x, y, color, count) {
  for (let i = 0; i < count; i++) {
    particles.push({
      x: x, y: y,
      vx: (Math.random() - 0.5) * 0.1,
      vy: (Math.random() - 0.5) * 0.1,
      life: 1,
      color: color,
      size: 2 + Math.random() * 3
    });
  }
}

function updateParticles(dt) {
  particles = particles.filter(pt => {
    pt.x += pt.vx * dt;
    pt.y += pt.vy * dt;
    pt.life -= dt * 2;
    return pt.life > 0;
  });
}

function updateHUD() {
  document.getElementById('hudTeam1').textContent = TEAMS[selectedTeam[0]].name.substring(0, 12);
  document.getElementById('hudTeam2').textContent = TEAMS[selectedTeam[1]].name.substring(0, 12);
  document.getElementById('hudScore').textContent = score[0] + ' - ' + score[1];
  
  const mins = Math.floor(matchTime / 60);
  const secs = Math.floor(matchTime % 60);
  document.getElementById('hudTime').textContent = mins + ':' + secs.toString().padStart(2, '0');
  
  const total = possession[0] + possession[1];
  const p1 = total > 0 ? Math.round(possession[0] / total * 100) : 50;
  document.getElementById('hudPossession').textContent = `Possession: ${p1}% - ${100-p1}%`;
  
  const active = players[myTeam || 0][activePlayer[myTeam || 0]];
  if (active) {
    document.getElementById('playerName').textContent = active.name;
    document.getElementById('staminaFill').style.width = active.stamina + '%';
  }
}

// ==================== INIT ====================
showScreen('mainMenu');
