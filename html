// ==================== NETWORKING ====================
let ws = null;
let netState = 'offline'; // offline, connecting, connected, playing
let myPlayerId = null;
let myTeam = 0; // 0 = home, 1 = away
let roomCode = null;
let isHost = false;
let opponentReady = false;
let imReady = false;
let lastPingTime = 0;
let latency = 0;
let networkInputs = { keys: {}, activePlayer: 0 };
let ballSync = null;
let syncTimer = 0;

function connectToServer(ip, port) {
  return new Promise((resolve, reject) => {
    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const url = `${protocol}//${ip}:${port}`;
    ws = new WebSocket(url);
    
    ws.onopen = () => {
      netState = 'connected';
      resolve();
    };
    
    ws.onmessage = (event) => {
      const msg = JSON.parse(event.data);
      handleServerMessage(msg);
    };
    
    ws.onclose = () => {
      netState = 'offline';
      if (gameState === 'playing') {
        alert('Connection lost! Returning to menu.');
        quitToMenu();
      }
    };
    
    ws.onerror = (err) => {
      netState = 'offline';
      reject(err);
    };
  });
}

function send(msg) {
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify(msg));
  }
}

function handleServerMessage(msg) {
  switch (msg.type) {
    case 'room_created':
      roomCode = msg.roomCode;
      myPlayerId = msg.playerId;
      isHost = true;
      myTeam = 0;
      document.getElementById('roomCodeDisplay').textContent = roomCode;
      document.getElementById('hostStatus').textContent = 'Connected';
      document.getElementById('hostStatus').className = 'online-status connected';
      document.getElementById('hostMessage').textContent = 'Waiting for opponent to join...';
      break;
      
    case 'player_joined':
      document.getElementById('hostMessage').textContent = 'Opponent joined! Select your team:';
      document.getElementById('hostTeamSelect').style.display = 'block';
      renderOnlineTeamSelect('hostTeamList', 0);
      break;
      
    case 'joined_room':
      roomCode = msg.roomCode;
      myPlayerId = msg.playerId;
      isHost = false;
      myTeam = 1;
      document.getElementById('joinStatus').textContent = 'Connected';
      document.getElementById('joinStatus').className = 'online-status connected';
      document.getElementById('joinTeamSelect').style.display = 'block';
      renderOnlineTeamSelect('joinTeamList', 1);
      break;
      
    case 'opponent_team':
      // Opponent selected their team
      if (isHost) {
        selectedTeam[1] = msg.teamIndex;
      } else {
        selectedTeam[0] = msg.teamIndex;
      }
      checkReadyState();
      break;
      
    case 'opponent_ready':
      opponentReady = true;
      checkReadyState();
      break;
      
    case 'match_start':
      selectedTeam = msg.teams;
      selectedFormation = msg.formations;
      matchDuration = msg.duration;
      startOnlineMatch();
      break;
      
    case 'input':
      if (msg.playerId !== myPlayerId) {
        networkInputs = msg.data;
      }
      break;
      
    case 'ball_sync':
      ballSync = msg.ball;
      break;
      
    case 'goal':
      if (msg.scoringTeam !== undefined) {
        scoreGoal(msg.scoringTeam, false);
      }
      break;
      
    case 'match_end':
      endMatch();
      break;
      
    case 'pong':
      latency = Date.now() - lastPingTime;
      document.getElementById('latencyDisplay').textContent = 'Ping: ' + latency + ' ms';
      break;
      
    case 'error':
      alert(msg.message);
      break;
  }
}

function renderOnlineTeamSelect(containerId, teamSlot) {
  const container = document.getElementById(containerId);
  container.innerHTML = '';
  TEAMS.forEach((team, i) => {
    const div = document.createElement('div');
    div.className = 'team-item' + (selectedTeam[teamSlot] === i ? ' selected' : '');
    div.onclick = () => {
      selectedTeam[teamSlot] = i;
      renderOnlineTeamSelect(containerId, teamSlot);
      send({ type: 'select_team', roomCode, teamIndex: i });
      checkReadyState();
    };
    const ovrColor = team.ovr >= 88 ? '#00ff44' : team.ovr >= 85 ? '#ffdd00' : '#ff4444';
    div.innerHTML = `
      <div class="team-flag" style="background: ${team.color}; color: ${team.dark};">${team.name.substring(0,2).toUpperCase()}</div>
