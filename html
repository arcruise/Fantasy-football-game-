  try {
    await connectToServer(ip, port);
    send({ type: 'create_room' });
  } catch (e) {
    alert('Failed to connect to server. Make sure the server is running.');
    showScreen('onlineMenu');
  }
}

async function joinOnlineGame() {
  const ip = document.getElementById('serverIP').value || 'localhost';
  const port = document.getElementById('serverPort').value || '3000';
  const code = document.getElementById('joinRoomCode').value.toUpperCase();
  if (code.length !== 4) { alert('Enter a valid 4-digit room code'); return; }
  showScreen('joinRoom');
  try {
    await connectToServer(ip, port);
    send({ type: 'join_room', roomCode: code });
  } catch (e) {
    alert('Failed to connect to server.');
    showScreen('onlineMenu');
  }
}

